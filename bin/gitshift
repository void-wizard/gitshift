#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/core.sh"
source "$SCRIPT_DIR/lib/ssh.sh"
source "$SCRIPT_DIR/lib/add.sh"
source "$SCRIPT_DIR/lib/list.sh"
source "$SCRIPT_DIR/lib/remove.sh"
source "$SCRIPT_DIR/lib/use.sh"
source "$SCRIPT_DIR/lib/who.sh"
source "$SCRIPT_DIR/lib/clone.sh"
source "$SCRIPT_DIR/lib/status.sh"

case "${1:-who}" in
  init)
    ensure_config
    echo "gitshift configuration is ready: $CONFIG_DIR"
    echo "Profile file: $PROFILE_FILE"
    ;;

  add)
    add_profile
    ;;

  list)
    list_profiles
    ;;

  remove)
    remove_profile "${2:-}"
    ;;

  use)
    use_profile "${2:-}"
    ;;

  who)
    current_profile
    ;;

  clone)
    clone_repo "${2:-}"
    ;;

  help|-h|--help)
    show_help
    ;;

  status)
    status
    ;;

  *)
    show_help
    exit 1
    ;;
esac