#!/usr/bin/env bash

# Enable strict Bash error handling
set -euo pipefail

# Directory used to store gitshift data
CONFIG_DIR="$HOME/.gitshift"

# File used to store Git identity profiles.
# Format: profile|name|email
# Example: work|Alice|alice@company.com
PROFILE_FILE="$CONFIG_DIR/profiles"

# Help text installed with gitshift
HELP_FILE="$CONFIG_DIR/bin/help.txt"

ensure_config() {
  mkdir -p "$CONFIG_DIR"
  touch "$PROFILE_FILE"
}

show_help() {
  if [[ -f "$HELP_FILE" ]]; then
    cat "$HELP_FILE"
    return
  fi

  echo "Help file not found: $HELP_FILE"
  echo "Please run the installer again."
}

# Ensure gitshift has been initialized
check_initialized() {
  if [[ -d "$CONFIG_DIR" && -f "$PROFILE_FILE" ]]; then
    return 0
  fi

  echo "gitshift is not initialized. Please run: gitshift init"
  exit 1
}

# Ensure the current directory is inside a Git repository
check_git_repo() {
  if command git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  echo "Current directory is not a Git repository."
  exit 1
}

# Add or replace a Git identity profile
add_profile() {
  check_initialized

  local key="${1:-}"
  local name="${2:-}"
  local email="${3:-}"

  # Exit if any required value is missing
  if [[ -z "$key" || -z "$name" || -z "$email" ]]; then
    echo "Usage: gitshift add <profile> <name> <email>"
    exit 1
  fi

  # Write the updated profiles file to a temp file first
  # then replace the original file in one step
  local tmp_file
  tmp_file="${PROFILE_FILE}.$$"

  trap 'rm -f "$tmp_file"' EXIT INT TERM

  {
    grep -v "^${key}|" "$PROFILE_FILE" || true
    echo "${key}|${name}|${email}"
  } > "$tmp_file"

  mv "$tmp_file" "$PROFILE_FILE"

  trap - EXIT INT TERM

  echo "Profile saved: $key"
}

# List all saved Git identity profiles
list_profiles() {
  check_initialized

  if [[ ! -s "$PROFILE_FILE" ]]; then
    echo "No profiles yet. Use: gitshift add <profile> <name> <email>"
    return
  fi

  while IFS='|' read -r key name email; do
    echo "$key: $name <$email>"
  done < "$PROFILE_FILE"
}

# Apply a saved profile to the current Git repository
use_profile() {
  check_initialized

  local key="${1:-}"

  if [[ -z "$key" ]]; then
    echo "Usage: gitshift use <profile>"
    exit 1
  fi

  check_git_repo

  local line
  line="$(grep "^${key}|" "$PROFILE_FILE" 2>/dev/null || true)"

  # Exit if the requested profile does not exist
  if [[ -z "$line" ]]; then
    echo "Profile not found: $key"
    exit 1
  fi

  # Extract name & email from the profile record
  local name email
  name="$(echo "$line" | cut -d'|' -f2)"
  email="$(echo "$line" | cut -d'|' -f3)"

  command git config --local user.name "$name"
  command git config --local user.email "$email"

  echo "Git identity switched for this repository:"
  echo "user.name=$name"
  echo "user.email=$email"

}

# Show the Git identity configured for the current repository
current_profile() {
  check_git_repo

  local name
  name="$(command git config --local --get user.name 2>/dev/null || echo "not configured")"

  local email
  email="$(command git config --local --get user.email 2>/dev/null || echo "not configured")"

  echo "user.name=$name"
  echo "user.email=$email"

}

# Show Git repository and identity information for git status hook
status() {
  local repo
  repo="$(command git rev-parse --show-toplevel 2>/dev/null || true)"

  local name
  name="$(command git config --local --get user.name 2>/dev/null || echo "not configured")"

  local email
  email="$(command git config --local --get user.email 2>/dev/null || echo "not configured")"

  echo "Git repository: ${repo:-not a Git repository}"
  echo "Git user.name: $name"
  echo "Git user.email: $email"
  echo
}

# Dispatch CLI commands
case "${1:-current}" in
  init)
    ensure_config
    echo "gitshift configuration is ready: $CONFIG_DIR"
    echo "Profile file: $PROFILE_FILE"
    ;;

  add)
    add_profile "${2:-}" "${3:-}" "${4:-}"
    ;;

  list)
    list_profiles
    ;;

  use)
    use_profile "${2:-}"
    ;;

  who)
    current_profile
    ;;

  help|-h|--help)
    show_help
    ;;

  status)
    status
    ;;

  *)
    show_help
    exit 1
    ;;
esac